<section
  class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-16 border-b border-brand-borderLight dark:border-brand-borderDark transition-custom">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">

    <!-- Left side: Main text and Selector -->
    <div class="lg:col-span-7 space-y-6">

      <!-- Typographic display representing the inner balance of minds -->
      <div class="space-y-2">
        <span class="text-xs font-mono tracking-widest text-stone-400 uppercase">Chronicles of a</span>
        <h1 class="text-4xl sm:text-5xl font-playfair font-extrabold tracking-tight leading-tight select-none">
          <span id="title-click-engineer" onclick="setMindset('engineer')"
            class="cursor-pointer transition-custom">Programmer</span>,
          <span id="title-click-analyst" onclick="setMindset('analyst')"
            class="cursor-pointer transition-custom font-serif italic font-normal">Analyst</span>, <br
            class="hidden sm:inline">
          and <span id="title-click-designer" onclick="setMindset('designer')"
            class="cursor-pointer transition-custom underline decoration-1 underline-offset-4">Designer</span>.
        </h1>
      </div>

      <!-- Animated Mindset Subtitle -->
      <div class="h-10 flex items-center">
        <p class="font-serif italic text-lg sm:text-xl text-stone-500 dark:text-stone-400 flex items-center">
          Currently debugging&nbsp;
          <span class="font-mono text-base sm:text-lg not-italic font-bold px-2 py-0.5 rounded transition-custom"
            id="interactive-span"
            style="color: var(--personality-color, #ea580c); background-color: rgba(234, 88, 12, 0.08);">
            life.py
          </span>
          <span class="inline-block w-1.5 h-4.5 bg-[var(--personality-color,#ea580c)] ml-0.5 cursor-blink align-middle"
            id="interactive-cursor"></span>
        </p>
      </div>

      <p class="font-serif text-base sm:text-lg text-stone-600 dark:text-stone-300 leading-relaxed max-w-xl">
        <%- config.description
          || 'This blog compiles my personal journey into AI development, geo intelligence, and software craftsmanship. Built with million-token context windows and a designer’s eye for visual hierarchy.'
          %>
      </p>

      <!-- Premium Contact Row -->
      <div
        class="flex flex-wrap gap-x-5 gap-y-2 text-xs font-mono text-stone-500 dark:text-stone-400 border-t border-brand-borderLight dark:border-brand-borderDark/40 pt-4 max-w-xl transition-custom">
        <a href="mailto:zcmmwang@gmail.com"
          class="flex items-center gap-1.5 hover:text-[var(--personality-color)] transition-colors">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          zcmmwang@gmail.com
        </a>
        <a href="https://x.com/ZhichengWang87" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-1.5 hover:text-[var(--personality-color)] transition-colors">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-current" stroke="none">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          @ZhichengWang87
        </a>
        <a href="https://github.com/Dogecat0" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-1.5 hover:text-[var(--personality-color)] transition-colors">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-current" stroke="none">
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
          Dogecat0
        </a>
      </div>
    </div>

    <!-- Right side: projects section -->
    <div class="lg:col-span-5">

      <!-- Active Systems widget -->
      <div
        class="p-6 bg-stone-100/20 dark:bg-stone-900/20 border border-brand-borderLight dark:border-brand-borderDark rounded-xl transition-custom">
        <h4
          class="text-xs font-mono font-bold tracking-widest text-stone-400 dark:text-stone-500 uppercase mb-4 flex items-center gap-2">
          <i data-lucide="git-merge" class="h-3.5 w-3.5"></i> Active Systems
        </h4>

        <div class="space-y-4">
          <!-- Dossigraphica -->
          <div class="space-y-1">
            <div class="flex items-center justify-between text-sm sm:text-base font-bold font-playfair">
              <a href="https://zhicheng-wang.com/Dossigraphica" target="_blank" rel="noopener noreferrer"
                class="hover:text-[var(--personality-color)] transition-colors">🌍 Dossigraphica</a>
              <span
                class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-400 border border-stone-200 dark:border-stone-700">Macro
                Geo Intelligence</span>
            </div>
            <p class="text-xs sm:text-sm font-serif text-stone-500 dark:text-stone-400 leading-relaxed">
              Visualizing corporate entities network mapping via LLM pipeline extractions.
            </p>
          </div>

          <!-- NearPulse -->
          <div class="space-y-1">
            <div class="flex items-center justify-between text-sm sm:text-base font-bold font-playfair">
              <a href="https://www.nearpulse.space" target="_blank" rel="noopener noreferrer"
                class="hover:text-[var(--personality-color)] transition-colors">📍 NearPulse</a>
              <span
                class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-400 border border-stone-200 dark:border-stone-700">Micro
                Geo Intelligence</span>
            </div>
            <p class="text-xs sm:text-sm font-serif text-stone-500 dark:text-stone-400 leading-relaxed">
              Micro-neighborhood dashboard analysis tool.
            </p>
          </div>

          <!-- Shotwise -->
          <div class="space-y-1 border-t border-dashed border-stone-200 dark:border-stone-800 pt-3">
            <div class="flex items-center justify-between text-sm sm:text-base font-bold font-playfair">
              <a href="https://www.shotwiseai.com" target="_blank" rel="noopener noreferrer"
                class="hover:text-[var(--personality-color)] transition-colors">📸 Shotwise</a>
              <span
                class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-400 border border-stone-200 dark:border-stone-700">Photography</span>
            </div>
            <p class="text-xs sm:text-sm font-serif text-stone-500 dark:text-stone-400 leading-relaxed">
              AI photography analyzer & aesthetic scoring platform.
            </p>
          </div>

          <!-- AperilexLabs -->
          <div class="space-y-1">
            <div class="flex items-center justify-between text-sm sm:text-base font-bold font-playfair">
              <a href="https://www.aperilexlabs.com" target="_blank" rel="noopener noreferrer"
                class="hover:text-[var(--personality-color)] transition-colors">📈 AperilexLabs</a>
              <span
                class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-400 border border-stone-200 dark:border-stone-700">Filing
                Analysis</span>
            </div>
            <p class="text-xs sm:text-sm font-serif text-stone-500 dark:text-stone-400 leading-relaxed">
              Financial analytics and corporate filing insights.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>