<header class="sticky top-0 z-40 bg-brand-bgLight/80 dark:bg-brand-bgDark/80 backdrop-blur-md border-b border-brand-borderLight dark:border-brand-borderDark transition-custom py-4 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    
    <!-- Top Title/Logo -->
    <a href="<%- url_for('/') %>" class="font-playfair text-xl font-bold tracking-tight transition-custom flex items-center gap-2 flex-shrink-0">
      <%= config.title %>
    </a>

    <!-- Navigation Menu -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      <% for (var i in theme.menu){ %>
        <a class="text-stone-600 dark:text-stone-300 hover:text-[var(--personality-hover-color)] transition-colors" href="<%- url_for(theme.menu[i]) %>"><%= i %></a>
      <% } %>
    </nav>

    <!-- Redesign Options Controller -->
    <div class="flex items-center gap-4">
      
      <!-- Personality Status Ribbon -->
      <div class="hidden sm:flex items-center gap-1.5 px-3 py-1 rounded-full bg-stone-100 dark:bg-stone-800 border border-brand-borderLight dark:border-brand-borderDark text-[11px] font-mono text-stone-500 dark:text-stone-400 transition-custom">
        <span>mindset_focus:</span>
        <span id="active-mindset-pill" class="text-brand-designer font-bold uppercase transition-colors inline-block w-[80px] text-left">Designer</span>
      </div>

      <!-- Light/Dark Toggle -->
      <button onclick="toggleTheme()" class="p-2 rounded-full hover:bg-stone-100 dark:hover:bg-stone-800 border border-brand-borderLight dark:border-brand-borderDark transition-custom text-stone-600 dark:text-stone-400" title="Toggle Light/Dark Mode">
        <i data-lucide="sun" id="theme-btn-icon" class="h-4.5 w-4.5"></i>
      </button>

    </div>
  </div>
</header>
