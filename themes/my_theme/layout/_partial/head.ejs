<head>
  <script>
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.classList.add('light');
      document.documentElement.classList.remove('dark');
    } else {
      document.documentElement.classList.add('dark');
      document.documentElement.classList.remove('light');
    }
  </script>
  <meta charset="utf-8">
  <%- partial('google-analytics') %>
  <%
  var title = page.title;

  if (is_archive()){
    title = __('archive_a');

    if (is_month()){
      title += ': ' + page.year + '/' + page.month;
    } else if (is_year()){
      title += ': ' + page.year;
    }
  } else if (is_category()){
    title = __('category') + ': ' + page.category;
  } else if (is_tag()){
    title = __('tag') + ': ' + page.tag;
  }
  %>
  <title><% if (title){ %><%= title %> | <% } %><%= config.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  
  <% if (page.description || page.excerpt || config.description) { %>
    <meta name="description" content="<%= (page.description || page.excerpt || config.description).replace(/<[^>]+>/g, '').replace(/\n/g, ' ').substring(0, 160) %>">
  <% } %>
  
  <% if (config.keywords || page.tags) { %>
    <meta name="keywords" content="<%= config.keywords %><% if (page.tags && page.tags.length) { %>, <%= page.tags.map(tag => tag.name).join(', ') %><% } %>">
  <% } %>
  
  <% if (page.permalink) { %>
    <link rel="canonical" href="<%= config.url %>/<%= page.path.replace('index.html', '') %>">
  <% } else if (is_home()) { %>
    <link rel="canonical" href="<%= config.url %>/">
  <% } %>
  
  <!-- Google Fonts: Cormorant Garamond, Playfair Display, Inter, JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,500;0,700;0,800;1,400&display=swap" rel="stylesheet">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <%- open_graph({twitter_id: theme.twitter, fb_admins: theme.fb_admins, fb_app_id: theme.fb_app_id}) %>
  <% if (config.feed) { %>
    <%- feed_tag() %>
  <% } else if (theme.rss) { %>
    <%- feed_tag(theme.rss) %>
  <% } %>
  <% if (theme.favicon){ %>
    <%- favicon_tag(theme.favicon) %>
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/icons/favicon-96x96.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/favicon-192x192.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
  <% } %>
  <%- css('css/output.css') %>
  <% if (config.prismjs.enable){ %>
    <link rel="stylesheet" href="<%- url_for("/css/prism.css") %>">
    <script src="<%- url_for('/js/prism.js') %>"></script>
  <% } %>
  <% if (theme.fancybox){ %>
    <%- css('fancybox/jquery.fancybox.min.css') %>
  <% } %>
  <% if (theme.links) {%>
    <%- css('https://cdn.jsdelivr.net/npm/fork-awesome@1.2.0/css/fork-awesome.min.css') %>
  <% } %>
</head>
