<%
  var words = strip_html(post.content).split(/\s+/).length;
  var minRead = Math.max(2, Math.ceil(words / 180));
%>

<% if (index) { %>
  <!-- ARTICLE LIST CARD -->
  <article class="post-hover-trigger space-y-3 cursor-pointer group pb-8 border-b border-brand-borderLight dark:border-brand-borderDark last:border-none" onclick="window.location.href='<%- url_for(post.path) %>'">
    <div class="flex items-center gap-3 text-xs font-mono text-stone-500 dark:text-stone-500">
      <span class="cat-indicator font-bold transition-colors uppercase">
        <% if (post.categories && post.categories.length) { %>
          <%= post.categories.map(cat => cat.name).join(' / ') %>
        <% } else { %>
          AI Development
        <% } %>
      </span>
      <span>•</span>
      <span><%= date(post.date, 'YYYY-MM-DD') %></span>
      <span>•</span>
      <span class="flex items-center gap-1"><i data-lucide="clock" class="h-3 w-3"></i> <%= minRead %> min read</span>
    </div>

    <h3 class="text-2xl font-playfair font-bold tracking-tight text-stone-800 dark:text-stone-100 cursor-pointer">
      <a href="<%- url_for(post.path) %>" onclick="event.stopPropagation();" class="hover:text-[var(--personality-color)] group-hover:text-[var(--personality-color)] transition-colors duration-200"><%= post.title %></a>
    </h3>

    <p class="font-serif text-base leading-relaxed text-stone-600 dark:text-stone-400 max-w-2xl">
      <%- post.excerpt ? strip_html(post.excerpt) : strip_html(post.content).substring(0, 200) + '...' %>
    </p>

    <div class="flex flex-wrap items-center justify-between pt-1 gap-2">
      <div class="flex flex-wrap gap-2 font-mono text-[10px]">
        <% if (post.tags && post.tags.length) { %>
          <% post.tags.forEach(tag => { %>
            <span class="px-2 py-0.5 rounded-full bg-stone-100 dark:bg-stone-800 text-stone-500">#<%= tag.name %></span>
          <% }) %>
        <% } %>
      </div>
      <a href="<%- url_for(post.path) %>" onclick="event.stopPropagation();" class="font-sans font-semibold text-xs text-[var(--personality-color)] hover:text-[var(--personality-hover-color)] transition-colors duration-200 flex items-center gap-1 group whitespace-nowrap">
        READ_MORE <span class="group-hover:translate-x-1 transition-transform">-&gt;</span>
      </a>
    </div>
  </article>
<% } else { %>
  <!-- ARTICLE DETAIL CARD -->
  <article class="space-y-6">
    <div class="flex items-center gap-3 text-xs font-mono text-stone-500 dark:text-stone-500">
      <span class="cat-indicator font-bold transition-colors uppercase">
        <% if (post.categories && post.categories.length) { %>
          <%= post.categories.map(cat => cat.name).join(' / ') %>
        <% } else { %>
          AI Development
        <% } %>
      </span>
      <span>•</span>
      <span><%= date(post.date, 'YYYY-MM-DD') %></span>
      <span>•</span>
      <span class="flex items-center gap-1"><i data-lucide="clock" class="h-3 w-3"></i> <%= minRead %> min read</span>
    </div>

    <h1 class="text-3xl md:text-4xl font-playfair font-bold tracking-tight text-stone-800 dark:text-stone-100">
      <%= post.title %>
    </h1>

    <div class="prose dark:prose-invert font-serif text-base md:text-lg leading-relaxed text-stone-700 dark:text-stone-300 max-w-none">
      <%- post.content %>
    </div>

    <div class="flex flex-wrap items-center justify-between pt-6 border-t border-brand-borderLight dark:border-brand-borderDark gap-4">
      <div class="flex flex-wrap gap-2 font-mono text-[10px]">
        <% if (post.tags && post.tags.length) { %>
          <% post.tags.forEach(tag => { %>
            <a href="<%- url_for(tag.path) %>" class="px-2 py-0.5 rounded-full bg-stone-100 dark:bg-stone-800 text-stone-500 hover:bg-stone-200 dark:hover:bg-stone-700 transition-colors">#<%= tag.name %></a>
          <% }) %>
        <% } %>
      </div>
    </div>
    
    <%- partial('post/nav') %>
  </article>
<% } %>
