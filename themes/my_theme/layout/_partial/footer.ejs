<footer class="border-t border-brand-borderLight dark:border-brand-borderDark py-10 mt-16 bg-stone-100/10 dark:bg-stone-900/10 transition-custom text-xs font-mono text-stone-400 dark:text-stone-500">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-2 gap-y-1">
      <span class="font-bold text-stone-600 dark:text-stone-400">&copy; <%= date(new Date(), 'YYYY') %></span>
      <span><%= config.author || config.title %></span>
    </div>
    
    <div class="flex items-center justify-center gap-3">
      <a href="<%- url_for('/sitemap.xml') %>" class="hover:text-[var(--personality-color)] transition-colors">Sitemap</a>
      <span class="text-stone-300 dark:text-stone-800">•</span>
      <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="text-[var(--personality-color)] hover:text-[var(--personality-hover-color)] transition-colors flex items-center gap-1 font-bold">
        Back to Top <i data-lucide="arrow-up" class="h-3 w-3"></i>
      </button>
    </div>
  </div>
</footer>
